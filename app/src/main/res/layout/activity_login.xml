<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Spacer Top -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

        <!-- Logo Icon -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal">

            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/rounded_white_box"/>

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                android:tint="#2E7D32"/>
        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Smartfeed Chick"
            android:textColor="#1B5E20"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Manage your farm assets with precision"
            android:textColor="#888888"
            android:textSize="13sp"
            android:gravity="center"
            android:fontFamily="sans-serif"/>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

        <!-- USERNAME LABEL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USERNAME OR EMAIL"
            android:textColor="#555555"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="6dp"/>

        <!-- Username Input -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_bg"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="14dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:tint="#AAAAAA"/>

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingLeft="44dp"
                android:paddingRight="14dp"
                android:hint="Enter your credentials"
                android:textColorHint="#BBBBBB"
                android:textColor="#333333"
                android:textSize="14sp"
                android:background="@null"
                android:inputType="textEmailAddress"
                android:fontFamily="sans-serif"/>
        </FrameLayout>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp"/>

        <!-- PASSWORD LABEL ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PASSWORD"
                android:textColor="#555555"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/txtForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot Password?"
                android:textColor="#2E7D32"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <!-- Password Input -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="52dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_bg"/>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center_vertical"
                android:layout_marginLeft="14dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:tint="#AAAAAA"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingLeft="44dp"
                android:paddingRight="48dp"
                android:hint="••••••••"
                android:textColorHint="#AAAAAA"
                android:textColor="#333333"
                android:textSize="16sp"
                android:background="@null"
                android:inputType="textPassword"
                android:fontFamily="sans-serif"/>

            <!-- Eye Icon -->
            <ImageView
                android:id="@+id/imgTogglePassword"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginRight="14dp"
                android:src="@android:drawable/ic_menu_view"
                android:tint="#AAAAAA"/>
        </FrameLayout>

        <!-- Remember Me -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <CheckBox
                android:id="@+id/cbRemember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#2E7D32"
                android:scaleX="0.85"
                android:scaleY="0.85"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="-4dp"
                android:text="Remember this device"
                android:textColor="#777777"
                android:textSize="13sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:text="Login to Dashboard  →"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_green_rounded"
            android:stateListAnimator="@null"/>

        <!-- OR Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:text="OR"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD"/>
        </LinearLayout>

        <!-- Sign Up Button -->
        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🧑‍🌾  Sign Up"
            android:textColor="#333333"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_outline_rounded"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"/>

        <!-- Contact Admin Button -->
        <Button
            android:id="@+id/btnContact"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🎧  Contact Administrator"
            android:textColor="#333333"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_outline_rounded"
            android:stateListAnimator="@null"/>

        <!-- Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp"/>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2024 SmartPoultry Systems. Industrial Precision for Agriculture."
            android:textColor="#BBBBBB"
            android:textSize="10sp"
            android:gravity="center"
            android:fontFamily="sans-serif"/>

        <!-- Bottom Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp"/>

    </LinearLayout>
</ScrollView>