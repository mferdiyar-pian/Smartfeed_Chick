<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F3">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="72dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="←"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pengaturan"
                    android:textColor="#1B2E1B"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"/>

                <!-- Info Icon -->
                <TextView
                    android:id="@+id/btnInfo"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="ⓘ"
                    android:textSize="20sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- ===== PROFILE CARD ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:paddingTop="28dp"
                android:paddingBottom="24dp"
                android:background="#FFFFFF">

                <!-- Avatar with Edit Badge -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <!-- Avatar Circle -->
                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_launcher_foreground"
                        android:background="@drawable/avatar_bg"
                        android:scaleType="centerCrop"/>

                    <!-- Edit Badge -->
                    <FrameLayout
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/badge_edit_bg">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="✎"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                    </FrameLayout>
                </FrameLayout>

                <!-- Name + Farmer ID -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginLeft="16dp"
                    android:layout_gravity="center_vertical">

                    <TextView
                        android:id="@+id/txtName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pianpunkk"
                        android:textColor="#1B2E1B"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/txtFarmerID"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Farmer ID: #SP-8829"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== AKUN & KEAMANAN SECTION ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AKUN &amp; KEAMANAN"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:paddingLeft="20dp"
                android:paddingTop="22dp"
                android:paddingBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profil Row -->
                    <LinearLayout
                        android:id="@+id/rowProfil"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="👤"
                                android:textSize="16sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Profil"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Detail personal dan kontak"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#CCCCCC"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F5F5F5" android:layout_marginLeft="66dp"/>

                    <!-- Ambang Notifikasi Row -->
                    <LinearLayout
                        android:id="@+id/rowNotifikasi"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🔔"
                                android:textSize="16sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ambang Notifikasi"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Atur batas suhu dan kelembaban"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#CCCCCC"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== KONFIGURASI SISTEM SECTION ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="KONFIGURASI SISTEM"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:paddingLeft="20dp"
                android:paddingTop="22dp"
                android:paddingBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Kalibrasi Perangkat Row -->
                    <LinearLayout
                        android:id="@+id/rowKalibrasi"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🔧"
                                android:textSize="16sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Kalibrasi Perangkat"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sinkronisasi sensor IoT"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#CCCCCC"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F5F5F5" android:layout_marginLeft="66dp"/>

                    <!-- Tema Aplikasi Row (with Toggle) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="🎨"
                                android:textSize="16sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tema Aplikasi"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/txtTemaMode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mode Terang / Gelap"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchTema"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="#FFFFFF"
                            app:trackTint="@drawable/switch_track_selector"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== BANTUAN & LAINNYA SECTION ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BANTUAN &amp; LAINNYA"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"
                android:paddingLeft="20dp"
                android:paddingTop="22dp"
                android:paddingBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Pusat Bantuan Row -->
                    <LinearLayout
                        android:id="@+id/rowBantuan"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="❓"
                                android:textSize="16sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pusat Bantuan"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Panduan dan FAQ"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#CCCCCC"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F5F5F5" android:layout_marginLeft="66dp"/>

                    <!-- Tentang Aplikasi Row -->
                    <LinearLayout
                        android:id="@+id/rowTentang"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:background="?attr/selectableItemBackground">

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_light_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="ℹ"
                                android:textSize="16sp"
                                android:gravity="center"
                                android:textColor="#4CAF50"/>
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginLeft="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tentang Aplikasi"
                                android:textColor="#1B2E1B"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Versi 1.0.0"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#CCCCCC"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== LOGOUT BUTTON ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp">

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Keluar dari Akun"
                    android:textColor="#D32F2F"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_logout"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:itemIconTint="@drawable/bottom_nav_selector"
        app:itemTextColor="@drawable/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
