<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center_horizontal">

    <!-- Top WiFi Icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_wifi"
            android:tint="#AAAAAA"/>
    </LinearLayout>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Circular Logo Container -->
    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center_horizontal">

        <!-- Dark green circle background -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/circle_dark_green"/>

        <!-- Chicken image in center -->
        <ImageView
            android:id="@+id/imgChicken"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:src="@drawable/chicken_logo"
            android:scaleType="centerInside"
            android:layout_marginBottom="12dp"/>

        <!-- CHICKEN label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="28dp"
            android:text="CHICKEN"
            android:textColor="#4CAF50"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"/>
    </FrameLayout>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="32dp"/>

    <!-- App Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smartfeed Chick"
        android:textColor="#1B5E20"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="INTELLIGENT FARMING SOLUTIONS"
        android:textColor="#757575"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:fontFamily="sans-serif"/>

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Progress Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:paddingBottom="24dp">

        <!-- Label and Percentage Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Loading"
                android:textColor="#555555"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif"/>

            <TextView
                android:id="@+id/txtPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30%"
                android:textColor="#333333"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:progress="30"
            android:progressDrawable="@drawable/progress_bar_custom"
            android:background="@drawable/progress_bg"/>
    </LinearLayout>

    <!-- Bottom Icons Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical">

        <!-- Module -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_module"
                android:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="MODULE"
                android:textColor="#888888"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V4.2"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="#E0E0E0"/>

        <!-- Mesh Network -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mesh"
                android:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="MESH"
                android:textColor="#888888"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NETWORK"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="30dp"
            android:background="#E0E0E0"/>

        <!-- Secure Mode -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_secure"
                android:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="SECURE"
                android:textColor="#888888"
                android:textSize="9sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODE"
                android:textColor="#888888"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>