<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F3">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="72dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="14dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="←"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:gravity="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOUSE 04 MONITORING"
                        android:textColor="#1B2E1B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        android:fontFamily="sans-serif-medium"/>

                    <!-- LIVE FEED · ACTIVE badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="3dp">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/circle_green_small"
                            android:layout_marginRight="5dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LIVE FEED · ACTIVE"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:fontFamily="sans-serif"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Bell with badge -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_popup_reminder"
                        android:tint="#888888"/>

                    <TextView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="top|end"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="8sp"
                        android:gravity="center"
                        android:background="@drawable/circle_red"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ===== STATS CARDS ROW 1: Temp + Humidity ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="16dp">

                <!-- Temperature Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Icon + NORMAL badge -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="🌡"
                                android:textSize="16sp"
                                android:gravity="center"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="NORMAL"
                                android:textColor="#4CAF50"
                                android:textSize="9sp"
                                android:gravity="end"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Temperature"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"/>

                        <TextView
                            android:id="@+id/txtTemperature"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="28.5°C"
                            android:textColor="#1B2E1B"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Humidity Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="💧"
                                android:textSize="16sp"
                                android:gravity="center"/>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="NORMAL"
                                android:textColor="#4CAF50"
                                android:textSize="9sp"
                                android:gravity="end"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Humidity"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"/>

                        <TextView
                            android:id="@+id/txtHumidity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="62%"
                            android:textColor="#1B2E1B"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ===== STATS CARD ROW 2: Ammonia ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="10dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:text="☁"
                                android:textSize="18sp"
                                android:textColor="#FF9800"
                                android:gravity="center"/>

                            <!-- ELEVATED badge -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="8dp"
                                android:text="ELEVATED"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:fontFamily="sans-serif-medium"
                                android:background="@drawable/badge_elevated_bg"
                                android:paddingLeft="8dp"
                                android:paddingRight="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Ammonia"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="sans-serif"/>

                        <TextView
                            android:id="@+id/txtAmmonia"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="22 ppm"
                            android:textColor="#1B2E1B"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ===== HISTORICAL ANALYTICS SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Historical Analytics (24h)"
                    android:textColor="#1B2E1B"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"/>

                <!-- Temperature Trend Chart Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Chart Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/circle_green_small"
                                    android:layout_marginRight="7dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Temperature Trends"
                                    android:textColor="#333333"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Updated 2m ago"
                                android:textColor="#BBBBBB"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif"/>
                        </LinearLayout>

                        <!-- Temperature Chart -->
                        <com.example.smartfeedchick.MonitoringChartView
                            android:id="@+id/chartTemperature"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:tag="green"/>

                        <!-- X axis labels -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="06:00"
                                android:textColor="#CCCCCC" android:textSize="9sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="12:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="18:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="00:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="end"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Ammonia Concentration Chart Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Chart Header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/circle_orange_small"
                                    android:layout_marginRight="7dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ammonia Concentration"
                                    android:textColor="#333333"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>

                            <!-- +12.4% change badge -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="↑ "
                                    android:textColor="#FF5722"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+12.4%"
                                    android:textColor="#FF5722"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Ammonia Chart -->
                        <com.example.smartfeedchick.MonitoringChartView
                            android:id="@+id/chartAmmonia"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:tag="orange"/>

                        <!-- X axis labels -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp">

                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="06:00"
                                android:textColor="#CCCCCC" android:textSize="9sp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="12:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="18:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="center"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="00:00"
                                android:textColor="#CCCCCC" android:textSize="9sp" android:gravity="end"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== FAN CONTROL + FULL REPORT BUTTONS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="20dp">

                <Button
                    android:id="@+id/btnFanControl"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="🌀  Fan Control"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_green_rounded_large"
                    android:stateListAnimator="@null"
                    android:layout_marginRight="10dp"/>

                <Button
                    android:id="@+id/btnFullReport"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="📋  Full Report"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_outline_rounded"
                    android:stateListAnimator="@null"
                    android:layout_marginLeft="10dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:itemIconTint="@drawable/bottom_nav_selector"
        app:itemTextColor="@drawable/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="8dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>